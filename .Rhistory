colSums(is.na(returns_industry))
colSums(is.na(returns_same))
# Convert to matrix format
data_geo <- as.matrix(returns_geo)
data_industry <- as.matrix(returns_industry)
data_same <- as.matrix(returns_same)
# Define univariate Garch specification
uspec <- ugarchspec(
mean.model = list(armaOrder = c(0,0)),   # constant mean
variance.model = list(garchOrder = c(1,1), model = "sGARCH"),
distribution.model = "norm"
)
replicate(3, uspec)
spec_geo <- dccspec(
uspec = multispec(replicate(5, uspec)),
dccOrder = c(1,1),
distribution = "mvnorm"
)
# Fit the model
fit_geo <- dccfit(
spec_geo,
data = data_geo,
fit.control = list(eval.se = TRUE)
)
fit_geo
# Convert to matrix format
