# Function to download data and compute monthly returns
get_monthly_returns <- function(tickers) {
returns_list <- list()
for (tkr in tickers) {
data <- getSymbols(tkr, from = date_from, to = date_to, auto.assign = FALSE)
returns <- monthlyReturn(data)
returns_list[[tkr]] <- returns
}
# Merge all monthly return series into one object
returns_data <- do.call(merge, returns_list)
colnames(returns_data) <- tickers
return(returns_data)
}
# Download data and calculate monthly returns
returns_geo <- get_monthly_returns(portfolio_geo)
returns_industry <- get_monthly_returns(portfolio_industry)
returns_same <- get_monthly_returns(portfolio_same)
# Check outputs
head(returns_geo)
head(returns_industry)
head(returns_same)
dim(returns_geo)
dim(returns_industry)
dim(returns_same)
