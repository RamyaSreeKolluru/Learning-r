# Question 1(a): Download price data and calculate monthly returns
# Define 3 portfolios
# Set sample period
date_from <- as.Date("2010-07-03")
date_to   <- as.Date("2026-03-31")
# Portfolio 1: Geographically diversified
portfolio_geo <- c("AAPL", "TD", "SAP", "BABA", "NESN.SW")
# Portfolio 2: Industry diversified
portfolio_industry <- c("AAPL", "JPM", "ENB", "JNJ", "WMT")
# Portfolio 3: Same industry (technology)
portfolio_same <- c("AAPL", "MSFT", "NVDA", "GOOGL", "AMD")
# Print portfolios
portfolio_geo
portfolio_industry
portfolio_same
# Function to download data and compute monthly returns
get_monthly_returns <- function(tickers) {
returns_list <- list()
for (tkr in tickers) {
data <- getSymbols(tkr, from = date_from, to = date_to, auto.assign = FALSE)
returns <- monthlyReturn(data)
returns_list[[tkr]] <- returns
}
# Merge all monthly return series into one object
returns_data <- do.call(merge, returns_list)
colnames(returns_data) <- tickers
return(returns_data)
}
# Download data and calculate monthly returns
returns_geo <- get_monthly_returns(portfolio_geo)
returns_industry <- get_monthly_returns(portfolio_industry)
returns_same <- get_monthly_returns(portfolio_same)
# Check outputs
head(returns_geo)
head(returns_industry)
head(returns_same)
dim(returns_geo)
dim(returns_industry)
dim(returns_same)
colSums(is.na(returns_geo))
colSums(is.na(returns_industry))
colSums(is.na(returns_same))
