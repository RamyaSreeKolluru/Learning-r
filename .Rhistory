# Function to maximize Sharpe ratio
optimize_sharpe <- function(mu, sigma, rf) {
mu <- as.numeric(mu)
sigma <- as.matrix(sigma)
n_assets <- length(mu)
# Negative Sharpe ratio
neg_sharpe <- function(w) {
w <- as.numeric(w)
port_ret <- sum(w * mu)
port_var <- as.numeric(t(w) %*% sigma %*% w)
port_sd  <- sqrt(port_var)
-(port_ret - rf) / port_sd
}
# Starting values
w0 <- rep(1 / n_assets + 0.001, n_assets)
# Constraints: no short-selling and sum of weights >= 1
ui <- rbind(diag(n_assets), rep(1, n_assets))
ci <- c(rep(0, n_assets), 1)
# Optimization
opt <- constrOptim(
theta = w0,
f = neg_sharpe,
grad = NULL,
ui = ui,
ci = ci,
method = "Nelder-Mead",
control = list(maxit = 10000, reltol = 1e-10)
)
# Normalize weights
w <- as.numeric(opt$par)
w <- w / sum(w)
# Portfolio statistics
port_ret <- sum(w * mu)
port_var <- as.numeric(t(w) %*% sigma %*% w)
port_sd  <- sqrt(port_var)
sharpe   <- (port_ret - rf) / port_sd
return(list(
weights = w,
return = port_ret,
sd = port_sd,
sharpe = sharpe
))
}
# Run optimization for each portfolio
result_geo <- optimize_sharpe(mu_geo, sigma_geo, rf_monthly)
names(result_geo$weights) <- portfolio_geo
result_industry <- optimize_sharpe(mu_industry, sigma_industry, rf_monthly)
names(result_industry$weights) <- portfolio_industry
result_same <- optimize_sharpe(mu_same, sigma_same, rf_monthly)
names(result_same$weights) <- portfolio_same
# Print results
cat("\n===== GEO PORTFOLIO =====\n")
print(round(result_geo$weights, 4))
cat("Expected return:", round(result_geo$return, 4), "\n")
cat("Standard deviation:", round(result_geo$sd, 4), "\n")
cat("Sharpe ratio:", round(result_geo$sharpe, 4), "\n")
cat("\n===== INDUSTRY PORTFOLIO =====\n")
print(round(result_industry$weights, 4))
cat("Expected return:", round(result_industry$return, 4), "\n")
cat("Standard deviation:", round(result_industry$sd, 4), "\n")
cat("Sharpe ratio:", round(result_industry$sharpe, 4), "\n")
cat("\n===== SAME-INDUSTRY PORTFOLIO =====\n")
print(round(result_same$weights, 4))
cat("Expected return:", round(result_same$return, 4), "\n")
cat("Standard deviation:", round(result_same$sd, 4), "\n")
cat("Sharpe ratio:", round(result_same$sharpe, 4), "\n")
