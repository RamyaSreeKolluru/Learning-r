rf_annual  <- 0.04
rf_monthly <- rf_annual / 12
optimize_sharpe <- function(mu, sigma, rf) {
n_assets <- length(mu)
# Negative Sharpe (because we minimize)
neg_sharpe <- function(w) {
port_ret <- sum(w * mu)
port_var <- as.numeric(t(w) %*% sigma %*% w)
port_sd  <- sqrt(port_var)
-(port_ret - rf) / port_sd
}
# Initial weights
w0 <- rep(1 / n_assets + 0.001, n_assets)
# Constraints
ui <- rbind(diag(n_assets), rep(1, n_assets))
ci <- c(rep(0, n_assets), 1)
# Optimization
opt <- constrOptim(
theta = w0,
f = neg_sharpe,
grad = NULL,
ui = ui,
ci = ci,
method = "Nelder-Mead"
)
# Normalize weights
w <- opt$par
w <- w / sum(w)
# Portfolio stats
port_ret <- sum(w * mu)
port_var <- as.numeric(t(w) %*% sigma %*% w)
port_sd  <- sqrt(port_var)
sharpe   <- (port_ret - rf) / port_sd
return(list(weights = w,
return = port_ret,
sd = port_sd,
sharpe = sharpe))
}
result_geo <- optimize_sharpe(mu_geo, sigma_geo, rf_monthly)
