uspec = multispec(replicate(5, uspec)),
dccOrder = c(1,1),
distribution = "mvnorm"
)
fit_same <- dccfit(spec_same, data = data_same)
# 1-step-ahead forecast (April 2026)
forecast_geo <- dccforecast(fit_geo, n.ahead = 1)
# Covariance matrix (5x5)
sigma_geo <- forecast_geo@mforecast$H[[1]]
# Mean returns (1x5 vector)
mu_geo <- as.numeric(forecast_geo@mforecast$mu)
names(mu_geo) <- colnames(data_geo)
# Print
cat("\n--- Forecasted Mean Returns (Geo Portfolio) ---\n")
print(mu_geo)
cat("\n--- Forecasted Covariance Matrix (Geo Portfolio) ---\n")
print(sigma_geo)
# Correlation matrix
cor_geo <- forecast_geo@mforecast$R[[1]]
cat("\n--- Forecasted Correlation Matrix ---\n")
print(cor_geo)
